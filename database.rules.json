{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",

        "progress": {
          "$moduleId": {
            ".validate": "newData.hasChildren(['visited'])",
            "visited":     { ".validate": "newData.isBoolean()" },
            "visitedAt":   { ".validate": "newData.isString() && newData.val().length < 30" },
            "completed":   { ".validate": "newData.isBoolean()" },
            "completedAt": { ".validate": "newData.isString() && newData.val().length < 30 || newData.val() === null" },
            "$other":      { ".validate": false }
          }
        },

        "activePath": {
          ".validate": "newData.isString() && newData.val().length < 100"
        },

        "challenges": {
          "$moduleId": {
            "$challengeId": {
              ".validate": "newData.isString() && newData.val().length < 30"
            }
          }
        },

        "notes": {
          "$moduleId": {
            ".validate": "newData.hasChildren(['text'])",
            "text":      { ".validate": "newData.isString() && newData.val().length < 10000" },
            "updatedAt": { ".validate": "newData.isString() && newData.val().length < 30" },
            "$other":    { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    ".read": false,
    ".write": false
  }
}
